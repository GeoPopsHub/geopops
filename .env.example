# GeoPops Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Your Census API key (get one at https://api.census.gov/data/key_signup.html)
CENSUS_API_KEY=

# Path to your Julia environment
# Examples:
#   Linux:   /home/username/.julia/environments/v1.9/
#   macOS:   /Users/username/.julia/environments/v1.9/
#   Windows: C:/Users/username/.julia/environments/v1.9/Project.toml
JULIA_ENV_PATH=
